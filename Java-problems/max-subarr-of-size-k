class Solution {
    public int maxSubarraySum(int[] arr, int k) {
        int sum = 0;
        int n = arr.length;
        
        for(int i=0 ; i<k ; i++){
            sum += arr[i];
        }
        
        int maxSum = sum;
        
        for(int i=k ; i<n ; i++){
            sum = sum + arr[i] - arr[i-k];
            maxSum = Math.max(sum,maxSum);
        }
        
        return maxSum;
    }
}